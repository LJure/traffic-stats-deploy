#!/bin/sh
# Blocks direct pushes to main from this shared worktree; GitHub protection remains the preferred server-side control.
while read local_ref local_sha remote_ref remote_sha
do
  if [ "$remote_ref" = "refs/heads/main" ] && [ "$local_sha" != "0000000000000000000000000000000000000000" ]
  then
    echo "Direct pushes to main are blocked. Create a user/* or codex/* branch and open a PR." >&2
    exit 1
  fi
done
exit 0
